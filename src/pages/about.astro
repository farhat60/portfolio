---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";

const base = "/portfolio/";

const points = [
  "Started with self-teaching and free online resources.",
  "Care about open tools, accessibility, and maintainable systems.",
  "Prefer practical engineering work that other people can reuse and extend.",
];
---

<BaseLayout
  title="Abdullah Farhat | About"
  description="Background and engineering approach of Abdullah Farhat."
>
  <SiteHeader activePage="about" />

  <main class="site-shell about-page">
    <section class="page-intro reveal">
      <SectionHeading eyebrow="About" />
      <p class="page-intro-copy">
        I&apos;m Syrian and grew up in Saudi Arabia before coming to the United
        States for college. Because my family lived there as temporary
        residents, many academic opportunities were limited, which pushed me
        toward self-teaching, free online resources, and practical systems work.
      </p>
    </section>

    <section class="about-hero reveal">
      <figure class="about-portrait">
        <img
          src={`${base}abdullah-portrait.jpg`}
          alt="Portrait of Abdullah Farhat"
          loading="lazy"
        />
      </figure>

      <div class="about-side">
        <article class="about-story">
          <p class="about-card-label">Background</p>
          <p>
            That background is part of why I care about open-source work,
            maintainable tooling, and engineering that lowers the barrier for
            the next person using it.
          </p>

          <ul class="about-points">
            {points.map((point) => <li>{point}</li>)}
          </ul>
        </article>

        <div class="about-contact">
          <p class="about-contact-label">Contact</p>
          <a href="mailto:afarhat@vassar.edu">afarhat@vassar.edu</a>
          <a href="https://github.com/farhat60">github.com/farhat60</a>
          <a href="https://www.linkedin.com/in/abhfarhat">linkedin.com/in/abhfarhat</a>
          <p class="about-contact-location">Poughkeepsie, New York</p>
        </div>
      </div>
    </section>

    <div class="about-return reveal">
      <a class="button button-secondary" href={base}>Return to portfolio</a>
    </div>
  </main>
</BaseLayout>
