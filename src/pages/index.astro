---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteHeader from "../components/SiteHeader.astro";

const base = "/portfolio/";

const featuredProjects = [
  {
    tag: "Web engineering",
    period: "TypeScript / HTML / CSS",
    title: "Heat and Cognition Experiment Toolkit",
    summary:
      "Built reusable, localized web experiments for an international behavioral research project.",
    detail:
      "Worked on configuration, deployment support, cross-device UI, and structured CSV output instead of one-off study code.",
  },
  {
    tag: "Game systems",
    period: "Java / libGDX",
    title: "Placebo World",
    summary:
      "Built a shared-codebase 2D adventure game prototype for desktop and Android.",
    detail:
      "Worked on overworld systems, screen lifecycle, inventory modeling, and multi-module libGDX architecture.",
  },
  {
    tag: "Network systems",
    period: "C / sockets",
    title: "IRC Server",
    summary:
      "Built a non-blocking IRC server in C with concurrent client handling and channel state.",
    detail:
      "Implemented registration, core IRC commands, numeric replies, and automated protocol-level robustness checks.",
  },
];

const openSourceContributions = [
  {
    title: "Spatial n-back plugin",
    repo: "jspsych-contrib",
    note: "Configurable TypeScript plugin for reusable cognitive testing.",
    href: "https://github.com/jspsych/jspsych-contrib/pull/174",
  },
  {
    title: "Columbia Card timeline",
    repo: "jspsych-timelines",
    note: "Reusable timeline package with documentation and configuration support.",
    href: "https://github.com/jspsych/jspsych-timelines/pull/72",
  },
  {
    title: "Go / No-Go timeline",
    repo: "jspsych-timelines",
    note: "Configurable task package for real web-based experiment flows.",
    href: "https://github.com/jspsych/jspsych-timelines/pull/62",
  },
  {
    title: "Core jsPsych fix",
    repo: "jsPsych",
    note: "Fixed `enable_button_after` behavior in core jsPsych.",
    href: "https://github.com/jspsych/jsPsych/pull/3563",
  },
];

const heroProof = [
  {
    value: "URSI Fellow",
    label: "Vassar Undergraduate Research Summer Institute.",
  },
  {
    value: "Weeks to hours",
    label: "Toolkit work reported to reduce study setup time in lab workflows.",
  },
];

const education = [
  {
    key: "vassar",
    label: "Vassar College",
    degree: "B.A. in Computer Science",
    meta: "Expected 2028",
    note: "Primary undergraduate degree.",
    coursework: [
      "Data Structures and Algorithms",
      "Software Design",
      "Computer Networks",
      "Theory of Computation",
      "Computer Organization",
    ],
  },
  {
    key: "dartmouth",
    label: "Dartmouth College",
    degree: "B.E. in Computer Engineering",
    meta: "Expected 2029",
    note: "Second degree through the dual-degree path.",
    coursework: [
      "Distributed Systems and Fields",
      "Embedded Systems",
      "Digital Electronics",
      "Electronics: Introduction to Linear and Digital Circuits",
      "Discrete and Probabilistic Systems",
    ],
  },
];

const experience = [
  {
    date: "May 2025 - Aug 2026",
    role: "Assistant Research Software Engineer",
    org: "de Leeuw Lab, Vassar College",
    body: "Builds reusable web experiment packages, localization patterns, and deployment tooling for open-source behavioral studies.",
  },
  {
    date: "Sep 2024 - Aug 2026",
    role: "Service Desk Assistant",
    org: "Computing and Information Services, Vassar College",
    body: "Resolved 20+ support tickets weekly across device troubleshooting, OS issues, hardware repair, and day-to-day campus support.",
  },
  {
    date: "May 2025 - May 2026",
    role: "House President",
    org: "Jewett House, Vassar College",
    body: "Leads a 20-person house team supporting a 223-resident community through planning, coordination, and resident advocacy.",
  },
  {
    date: "2024 - May 2026",
    role: "Tech Chair and Webmaster",
    org: "Coders++ and The Miscellany News",
    body: "Supports open-source contribution workflows and the digital publishing stack for Vassar's student newspaper.",
  },
];
---

<BaseLayout
  title="Abdullah Farhat | Portfolio"
  description="Portfolio for Abdullah Farhat, a Vassar computer science student and Dartmouth computer engineering dual-degree student interested in full-stack and general software engineering, with public work in web tooling and open-source packages."
>
  <SiteHeader activePage="home" />

  <main class="site-shell" id="top">
    <section class="hero reveal">
      <div class="hero-main">
        <div class="hero-intro">
          <div class="hero-copy-block">
            <h1>Abdullah Farhat</h1>
            <p class="hero-role">
              Assistant Research Software Engineer at jsPsych
            </p>
            <p class="hero-copy">
              Building reusable web tooling, experiment infrastructure, and open-source packages. Interested in full-stack and general software engineering.
            </p>
            <div class="hero-actions">
              <a class="button button-primary button-email" href="mailto:afarhat@vassar.edu">Email</a>
              <a class="button button-secondary button-github" href="https://github.com/farhat60">GitHub</a>
              <a class="button button-secondary button-linkedin" href="https://www.linkedin.com/in/abhfarhat">LinkedIn</a>
              <a class="button button-secondary button-about" href={`${base}about/`}>About</a>
            </div>
          </div>

          <figure class="hero-photo">
            <img
              src={`${base}abdullah-headshot.jpg`}
              alt="Headshot of Abdullah Farhat"
              loading="eager"
            />
          </figure>
        </div>
        <div class="proof-strip">
          {
            heroProof.map((item) => (
              <div class="proof-item">
                <p class="proof-value">{item.value}</p>
                <p class="proof-label">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section reveal" id="work">
      <SectionHeading eyebrow="Work" />

      <div class="project-grid">
        {
          featuredProjects.map((project) => (
            <article class="project-card">
              <div class="card-top">
                <p class="case-tag">{project.tag}</p>
                <p class="case-period">{project.period}</p>
              </div>
              <h3>{project.title}</h3>
              <p class="project-summary">{project.summary}</p>
              <p class="project-detail">{project.detail}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section reveal" id="open-source">
      <SectionHeading eyebrow="Open source" />

      <div class="open-source-list">
        {
          openSourceContributions.map((item) => (
            <article class="open-source-row">
              <div class="open-source-copy">
                <div class="card-top">
                  <p class="case-tag">{item.repo}</p>
                </div>
                <h3>{item.title}</h3>
                <p>{item.note}</p>
              </div>
              <a class="inline-link" href={item.href}>View PR</a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section reveal" id="experience">
      <SectionHeading eyebrow="Experience" />

      <div class="experience-grid">
        {
          experience.map((item) => (
            <article class="experience-card">
              <p class="experience-date">{item.date}</p>
              <h3>{item.role}</h3>
              <p class="experience-org">{item.org}</p>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section reveal" id="education">
      <SectionHeading eyebrow="Education" />

      <div class="education-grid">
        <article class="education-card">
          <div class="education-list">
            {
              education.map((item, index) => (
                <button
                  type="button"
                  class:list={["education-tab", index === 0 && "is-active"]}
                  data-education-tab
                  data-education-key={item.key}
                  data-education-label={item.label}
                  data-coursework={item.coursework.join("|")}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {/* Clicking a school updates the coursework card on the right. */}
                  <p class="education-label">{item.meta}</p>
                  <h3 class="education-school">{item.label}</h3>
                  <p class="education-degree">{item.degree}</p>
                  <p class="education-note">{item.note}</p>
                </button>
              ))
            }
          </div>
        </article>

        <article class="education-card coursework-card" data-coursework-panel>
          <p class="education-label">Selected coursework</p>
          <p class="coursework-school" data-coursework-label>{education[0].label}</p>
          <ul class="chip-list" data-coursework-list>
            {education[0].coursework.map((course) => <li>{course}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <footer class="contact-panel reveal" id="contact">
      <div class="contact-copy">
        <p class="eyebrow">Contact</p>
        <h2>Open to internships and early-career software roles.</h2>
        <p>
          Full-stack, product, developer tooling, and general software
          engineering roles are the best fit.
        </p>
      </div>
      <div class="contact-links">
        <a href="mailto:afarhat@vassar.edu">afarhat@vassar.edu</a>
        <a href="https://github.com/farhat60">github.com/farhat60</a>
        <a href="https://www.linkedin.com/in/abhfarhat">linkedin.com/in/abhfarhat</a>
        <p>Poughkeepsie, New York</p>
        <p>Willing to relocate</p>
      </div>
    </footer>
  </main>

  <script is:inline>
    // Read the selected school's coursework from data attributes and swap the chips.
    const educationTabs = Array.from(
      document.querySelectorAll("[data-education-tab]")
    );
    const courseworkList = document.querySelector("[data-coursework-list]");
    const courseworkLabel = document.querySelector("[data-coursework-label]");

    if (educationTabs.length > 0 && courseworkList && courseworkLabel) {
      const renderCoursework = (tab) => {
        // Rebuild the chip list from the selected school's coursework data.
        const courses = (tab.dataset.coursework || "")
          .split("|")
          .map((course) => course.trim())
          .filter(Boolean);

        courseworkLabel.textContent = tab.dataset.educationLabel || "";
        courseworkList.innerHTML = "";

        courses.forEach((course) => {
          const item = document.createElement("li");
          item.textContent = course;
          courseworkList.appendChild(item);
        });
      };

      educationTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          // Toggle the active school and keep the button state in sync for screen readers.
          educationTabs.forEach((item) => {
            const isActive = item === tab;
            item.classList.toggle("is-active", isActive);
            item.setAttribute("aria-pressed", String(isActive));
          });

          renderCoursework(tab);
        });
      });

      renderCoursework(educationTabs[0]);
    }
  </script>
</BaseLayout>
