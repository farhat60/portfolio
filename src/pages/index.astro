---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteHeader from "../components/SiteHeader.astro";
const base = "/portfolio/";

const proofPoints = [
  { value: "4", label: "merged public jsPsych PRs that are worth opening" },
  { value: "2", label: "degrees across the Vassar and Dartmouth dual-degree path" },
  { value: "20+", label: "technical support tickets resolved weekly at Vassar" },
  { value: "223", label: "residents supported through house leadership" },
];

const featuredProjects = [
  {
    tag: "Research software",
    period: "2025 - Present",
    title: "Heat and Cognition Research Infrastructure",
    summary:
      "Reusable web experiment tooling for an international behavioral research effort studying cognition under extreme heat.",
    highlights: [
      "Reusable task packages instead of one-off experiment builds.",
      "Cross-device UI, localization-ready content, deployment workflow support, and structured CSV output.",
      "Contributed to open tooling reported to reduce study setup from weeks to hours.",
    ],
  },
  {
    tag: "Systems project",
    period: "Course collaboration",
    title: "Placebo World",
    summary:
      "A libGDX game project that shows architecture, rendering setup, and collaborative systems work outside the research-software track.",
    highlights: [
      "Worked on MVC structuring, screen lifecycle setup, and camera or viewport fundamentals.",
      "Supported debugging, asset servicing, and sequence-diagram planning in a team setting.",
      "Built with Java, libGDX, Gradle, and a tiled-map workflow.",
    ],
  },
];

const openSourceContributions = [
  {
    title: "Spatial n-back plugin",
    repo: "jspsych-contrib",
    note: "Merged a configurable spatial n-back plugin for reusable cognitive testing in the broader jsPsych ecosystem.",
    href: "https://github.com/jspsych/jspsych-contrib/pull/174",
  },
  {
    title: "Columbia Card timeline",
    repo: "jspsych-timelines",
    note: "Added a standardized timeline package for the Columbia Card Task with the structure expected for reuse.",
    href: "https://github.com/jspsych/jspsych-timelines/pull/72",
  },
  {
    title: "Go / No-Go timeline",
    repo: "jspsych-timelines",
    note: "Co-developed a configurable Go / No-Go task package with public PR history that shows iteration and collaboration.",
    href: "https://github.com/jspsych/jspsych-timelines/pull/62",
  },
  {
    title: "Core jsPsych fix",
    repo: "jsPsych",
    note: "Fixed `enable_button_after` behavior in core, which is the kind of small but important change downstream experiment UIs depend on.",
    href: "https://github.com/jspsych/jsPsych/pull/3563",
  },
];

const education = [
  {
    label: "Vassar College",
    degree: "B.A. in Computer Science",
    meta: "Expected 2028",
    note: "Primary undergraduate degree.",
  },
  {
    label: "Dartmouth College",
    degree: "B.E. dual degree",
    meta: "Expected 2029",
    note: "Engineering degree through the dual-degree path.",
  },
];

const coursework = [
  "Data Structures and Algorithms",
  "Software Design",
  "Computer Networks",
  "Theory of Computation",
  "Computer Organization",
  "Linear Algebra",
];

const experience = [
  {
    date: "May 2025 - Present",
    role: "Assistant Research Software Engineer",
    org: "de Leeuw Lab, Vassar College",
    body: "Builds reusable experiment packages, localization patterns, and deployment tooling for open-source behavioral studies.",
  },
  {
    date: "Sep 2024 - May 2025",
    role: "Service Desk Assistant",
    org: "Computing and Information Services, Vassar College",
    body: "Resolved 20+ support tickets weekly across device troubleshooting, OS issues, hardware repair, and day-to-day campus support.",
  },
  {
    date: "May 2025 - Present",
    role: "House President",
    org: "Jewett House, Vassar College",
    body: "Leads a 20-person house team supporting a 223-resident community through event planning, coordination, and resident advocacy.",
  },
  {
    date: "2024 - Present",
    role: "Tech Chair and Webmaster",
    org: "Coders++ and The Miscellany News",
    body: "Guides open-source contribution workflows and supports the digital publishing stack for Vassar's student newspaper.",
  },
];
---

<BaseLayout
  title="Abdullah Farhat | Portfolio"
  description="Portfolio for Abdullah Farhat, a Vassar and Dartmouth dual-degree computer science student building open-source research software and reusable web experiment tooling."
>
  <SiteHeader activePage="home" />

  <main class="site-shell" id="top">
    <section class="hero reveal">
      <div class="hero-main">
        <p class="eyebrow">Abdullah Farhat</p>
        <h1>Open-source research software for real studies.</h1>
        <p class="hero-role">
          Dual-degree Vassar and Dartmouth student building reusable web
          experiments, public task packages, and deployment-ready research
          tooling.
        </p>
        <p class="hero-copy">
          The strongest signal here is practical engineering: configurable
          experiment infrastructure, localization-ready interfaces,
          cross-device behavior, and public contribution history that can be
          opened and inspected.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="mailto:afarhat@vassar.edu">Email</a>
          <a class="button button-secondary" href="https://github.com/farhat60">GitHub</a>
          <a class="button button-secondary" href="https://www.linkedin.com/in/abhfarhat">LinkedIn</a>
        </div>
      </div>

      <aside class="hero-side">
        <article class="hero-stat">
          <p class="side-label">Current</p>
          <p class="side-title">Assistant Research Software Engineer</p>
          <p class="side-body">de Leeuw Lab, Vassar College</p>
        </article>
        <article class="hero-stat">
          <p class="side-label">Education</p>
          <p class="side-title">Vassar B.A. 2028 / Dartmouth B.E. 2029</p>
          <p class="side-body">
            Computer Science at Vassar, engineering dual-degree path through
            Dartmouth.
          </p>
        </article>
        <article class="hero-stat">
          <p class="side-label">Looking for</p>
          <p class="side-title">Internships and early-career software roles</p>
          <p class="side-body">
            Research software, developer tooling, and strong engineering teams.
          </p>
        </article>
      </aside>
    </section>

    <section class="proof-strip reveal" aria-label="Quick proof">
      {
        proofPoints.map((item) => (
          <article class="proof-item">
            <p class="proof-value">{item.value}</p>
            <p class="proof-label">{item.label}</p>
          </article>
        ))
      }
    </section>

    <section class="section reveal" id="work">
      <SectionHeading
        eyebrow="Selected work"
        title="Start with the strongest technical signal."
        body="The work below is the clearest view of how I build: reusable infrastructure first, then public contribution history that can be inspected directly."
      />

      <div class="project-grid">
        {
          featuredProjects.map((project) => (
            <article class="project-card">
              <div class="card-top">
                <p class="case-tag">{project.tag}</p>
                <p class="case-period">{project.period}</p>
              </div>
              <h3>{project.title}</h3>
              <p class="project-summary">{project.summary}</p>
              <ul class="project-highlights">
                {project.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section reveal" id="open-source">
      <SectionHeading
        eyebrow="Open source"
        title="Merged PRs are the proof, not just the repo names."
        body="These links make contribution history easy to verify. They show authorship, iteration, and the kind of work that survives public review."
      />

      <div class="open-source-grid">
        {
          openSourceContributions.map((item) => (
            <article class="open-source-card">
              <div class="card-top">
                <p class="case-tag">{item.repo}</p>
                <p class="case-period">Merged PR</p>
              </div>
              <h3>{item.title}</h3>
              <p>{item.note}</p>
              <a class="inline-link" href={item.href}>Open PR</a>
            </article>
          ))
        }
      </div>

      <p class="section-note">
        Current in-progress work includes heat-common-resources,
        pattern-comparison, speeded-matching, and flanker timelines. They are
        useful evidence of momentum, but the merged PRs are the strongest
        recruiter-facing proof right now.
      </p>
    </section>

    <section class="section reveal" id="education">
      <SectionHeading
        eyebrow="Education"
        title="Dual-degree path, kept compact."
      />

      <div class="education-grid">
        <article class="education-card">
          <div class="education-list">
            {
              education.map((item) => (
                <div class="education-item">
                  <p class="education-label">{item.label}</p>
                  <h3>{item.degree}</h3>
                  <p class="education-meta">{item.meta}</p>
                  <p class="education-note">{item.note}</p>
                </div>
              ))
            }
          </div>
        </article>

        <article class="education-card">
          <p class="education-label">Selected coursework</p>
          <ul class="chip-list">
            {coursework.map((course) => <li>{course}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="section reveal" id="experience">
      <SectionHeading
        eyebrow="Experience"
        title="Technical work, support work, and leadership."
      />

      <div class="experience-grid">
        {
          experience.map((item) => (
            <article class="experience-card">
              <p class="experience-date">{item.date}</p>
              <h3>{item.role}</h3>
              <p class="experience-org">{item.org}</p>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section reveal about-preview">
      <article class="about-preview-copy">
        <SectionHeading
          eyebrow="Background"
          title="Built through constraint, aimed at useful systems."
          body="The full background lives on a separate page so the homepage stays recruiter-first. The short version is that limited access pushed me toward self-teaching, open tools, and software that lowers barriers."
        />

        <p>
          I&apos;m Syrian and grew up in Saudi Arabia, where my family lived as
          temporary residents. That experience shaped what I value now:
          systems that are clear, reusable, and genuinely accessible to people
          who do not start with insider access.
        </p>

        <a class="button button-secondary" href={`${base}about/`}>Read background</a>
      </article>

      <aside class="about-preview-visual">
        <div class="portrait-frame">
          <img
            src={`${base}portrait.jpg`}
            alt="Portrait of Abdullah Farhat"
            loading="lazy"
          />
        </div>
      </aside>
    </section>

    <footer class="contact-panel reveal" id="contact">
      <div class="contact-copy">
        <p class="eyebrow">Contact</p>
        <h2>Available for internships and early-career engineering roles.</h2>
        <p>
          I&apos;m looking for teams where strong technical judgment, useful
          systems, and clear execution matter more than hype.
        </p>
      </div>
      <div class="contact-links">
        <a href="mailto:afarhat@vassar.edu">afarhat@vassar.edu</a>
        <a href="https://github.com/farhat60">github.com/farhat60</a>
        <a href="https://www.linkedin.com/in/abhfarhat">linkedin.com/in/abhfarhat</a>
        <p>Poughkeepsie, New York</p>
        <p>Willing to relocate</p>
      </div>
    </footer>
  </main>
</BaseLayout>
