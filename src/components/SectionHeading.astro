---
interface Props {
  eyebrow: string;
  body?: string;
}

const { eyebrow, body } = Astro.props;
---

<div class="section-heading">
  <div class="section-heading-row">
    <p class="section-title">{eyebrow}</p>
    <span class="section-line" aria-hidden="true"></span>
  </div>
  {body && <p class="section-body">{body}</p>}
</div>
