---
interface Link {
  key: string;
  label: string;
  href: string;
}

interface Props {
  activePage?: string;
}

const { activePage = "home" } = Astro.props;
const base = "/portfolio/";

const links: Link[] = [
  { key: "work", label: "Work", href: `${base}#work` },
  { key: "open-source", label: "Open Source", href: `${base}#open-source` },
  { key: "experience", label: "Experience", href: `${base}#experience` },
  { key: "education", label: "Education", href: `${base}#education` },
  { key: "contact", label: "Contact", href: `${base}#contact` },
];

const sectionKeys = new Set([
  "work",
  "open-source",
  "experience",
  "education",
  "contact",
]);
const onHome = activePage === "home";
const brandHref = onHome ? "#top" : base;
---

<div class="header-wrap">
  <header class="site-header">
    <a
      class="brand-mark"
      href={brandHref}
      data-scroll-top={onHome ? "true" : undefined}
    >
      Abdullah Farhat
    </a>

    <div class="header-actions">
      <nav class="site-nav" aria-label="Primary">
        <span class="nav-indicator" aria-hidden="true"></span>
        {
          links.map((link) => {
            const href = onHome && sectionKeys.has(link.key)
              ? `#${link.key}`
              : link.href;
            const isSectionLink = onHome && href.startsWith("#");

            return (
              <a
                href={href}
                data-nav-link={isSectionLink ? "true" : undefined}
                class:list={[!isSectionLink && activePage === link.key && "is-active"]}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>

      <a
        class:list={["header-page-link", activePage === "about" && "is-active"]}
        href={`${base}about/`}
      >
        About
      </a>
    </div>
  </header>
</div>
